{% macro page_shell(page_key, page_title=None) %}
{% set page_titles = _o_["load_yaml"]("pages.yaml") %}
<!DOCTYPE html>
<html lang="en" translate="no">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=ABeeZee&family=Spectral:ital,wght@0,200;0,300;0,400;0,500;0,600;0,700;0,800;1,200;1,300;1,400;1,500;1,600;1,700;1,800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="style.css">
  <title>{{ page_title or _o_["lookup"](page_titles, page_key, page_key) }}</title>
</head>
<body>
  {{ src["header.html"] }}
  {{ caller() }}
  {{ src["footer.html"] }}
</body>
</html>
{% endmacro %}
